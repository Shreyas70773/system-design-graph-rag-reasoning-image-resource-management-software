# Brand-Aligned Content Generation Platform
# Environment Variables Template
# Copy this file to .env and fill in your values

# ===================
# APPLICATION SETTINGS
# ===================
DEBUG=true

# ===================
# NEO4J AURA DATABASE
# ===================
# Get these from: https://aura.neo4j.io
# Create a FREE instance and copy the connection details
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# ===================
# HUGGING FACE API
# ===================
# Get token from: https://huggingface.co/settings/tokens
# Create a token with "read" permissions
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================
# GROQ API
# ===================
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================
# OPENROUTER IMAGE GENERATION
# ===================
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Default image model used by Brand DNA generation and layer composer
OPENROUTER_IMAGE_MODEL=openai/gpt-5-image
# Optional override for requested output modalities (comma-separated), e.g. image or image,text
OPENROUTER_IMAGE_MODALITIES=image,text

# ===================
# CLOUDFLARE R2 (Optional)
# ===================
# Only needed for production image storage
# Get from: https://dash.cloudflare.com/ -> R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=brand-content

# ===================
# CAPSTONE LOCAL MODELS
# ===================
# SAM 2 checkpoint file
CAPSTONE_SAM2_CHECKPOINT=checkpoints/sam2.1_hiera_large.pt
CAPSTONE_SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml

# LaMa local repo + Big-LaMa weights
CAPSTONE_LAMA_REPO_PATH=external/lama
CAPSTONE_LAMA_MODEL_PATH=models/big-lama
CAPSTONE_LAMA_PYTHON=python
CAPSTONE_LAMA_REFINER_GPU_IDS=0,
CAPSTONE_LAMA_REFINER_MODULO=8
CAPSTONE_LAMA_REFINER_N_ITERS=8
CAPSTONE_LAMA_REFINER_LR=0.0012
CAPSTONE_LAMA_REFINER_MIN_SIDE=512
CAPSTONE_LAMA_REFINER_MAX_SCALES=2
CAPSTONE_LAMA_REFINER_PX_BUDGET=1400000
CAPSTONE_LAMA_REFINER_MAX_MASK_AREA_FRACTION=0.35
CAPSTONE_LAMA_ALLOW_WINDOWS_REFINE=false
CAPSTONE_LAMA_RETRY_CPU_ON_CUDA_FAILURE=true

# Runtime
CAPSTONE_DEVICE=auto
CAPSTONE_ALLOW_MOCK_FALLBACKS=false
