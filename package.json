{
  "name": "brand-gen-dev-runner",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npx --yes concurrently -k -n BACKEND,FRONTEND -c green,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:frontend": "cd frontend && npm run dev -- --host 127.0.0.1 --port 5173"
  }
}